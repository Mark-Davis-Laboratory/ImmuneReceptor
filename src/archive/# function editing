using Random
using StatsBase  # sample, countmap
using Graphs

# you already have this
function get_clusters_and_sizes(g)
    clusters = connected_components(g)
    sizes = [length(c) for c in clusters]
    return clusters, sizes
end

"""
network_size_pvals_freq

Compute network.size.score-like p-values via simulation.

- g_sample: your built MetaGraph from the sample
- cdrs_ref: reference DataFrame you can pass to make_edges (must include :cdr3)
- motifs:   output of find_significant_motifs (iterable of (motif => pval))
- nsim:     number of simulations
- isglobal/islocal: must match how you built g_sample
- min_cluster_size: ignore clusters smaller than this in both observed & simulated
- pval uses: fraction of sims where (max cluster size) >= observed size
"""
function network_size_pvals_freq(
    g_sample,
    cdrs_ref,
    motifs;
    nsim::Int=500,
    isglobal::Bool=true,
    islocal::Bool=true,
    min_cluster_size::Int=2,
    rng::AbstractRNG=Random.default_rng(),
)

    n_sample = nv(g_sample)
    n_ref = nrow(cdrs_ref)
    n_ref >= n_sample || error("Reference set must have at least as many rows as the sample graph vertices.")

    # observed cluster sizes
    clusters_obs, sizes_obs_all = get_clusters_and_sizes(g_sample)
    keep = findall(>=(min_cluster_size), sizes_obs_all)
    clusters_obs = clusters_obs[keep]
    sizes_obs = sizes_obs_all[keep]

    # if nothing to score
    if isempty(sizes_obs)
        return (
            clusters=clusters_obs,
            sizes=Int[],
            pvals=Float64[],
            sim_max_sizes=Int[],
            sim_max_hist=Dict{Int,Int}(),
        )
    end

    # simulate: store max cluster size per simulation
    sim_max_sizes = Vector{Int}(undef, nsim)

    for sim in 1:nsim
        idx = sample(rng, 1:n_ref, n_sample; replace=false)
        sub = cdrs_ref[idx, :]

        # reindex rows so your make_edges() indexing is consistent
        sub[!, :row_index] = collect(1:nrow(sub))

        g_ref = make_edges(sub, motifs, isglobal, islocal)
        _, sim_sizes = get_clusters_and_sizes(g_ref)

        # apply same min_cluster_size filter
        sim_sizes = [s for s in sim_sizes if s >= min_cluster_size]

        sim_max_sizes[sim] = isempty(sim_sizes) ? 0 : maximum(sim_sizes)
    end

    # histogram (optional, but useful for debugging/plotting)
    sim_max_hist = countmap(sim_max_sizes)

    # pval per observed cluster size: P(max >= size)
    pvals = Float64[]
    for s_obs in sizes_obs
        wins = count(>=(s_obs), sim_max_sizes)
        p = wins / nsim
        p = (p == 0.0) ? (1.0 / nsim) : p
        push!(pvals, p)
    end

    return (
        clusters=clusters_obs,
        sizes=sizes_obs,
        pvals=pvals,
        sim_max_sizes=sim_max_sizes,
        sim_max_hist=sim_max_hist,
    )
end

